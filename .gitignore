# See https://help.github.com/articles/ignoring-files/

# ─── Dependencies ─────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js ──────────────────────────────────────────────────
/.next/
/out/
/build
.turbo

# ─── Environment & secrets ────────────────────────────────────
# Never commit secrets — use .env.example as the template.
.env
.env.*
!.env.example

# ─── TypeScript ───────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Testing ──────────────────────────────────────────────────
/coverage
/playwright-report/
/test-results/
/blob-report/
/playwright/.cache/

# ─── Prisma / SQLite (local dev database) ─────────────────────
/prisma/*.db
/prisma/*.db-journal
/prisma/*.db-wal
/prisma/*.db-shm
/dist-seed/

# ─── Logs & debug ─────────────────────────────────────────────
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.eslintcache

# ─── Deployment ───────────────────────────────────────────────
.vercel

# ─── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Editors & IDEs ─────────────────────────────────────────────
.idea/
*.swp
*.swo
*~
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# ─── Certificates & keys ──────────────────────────────────────
*.pem
*.key
*.p12
*.pfx

# ─── Misc ─────────────────────────────────────────────────────
*.local
